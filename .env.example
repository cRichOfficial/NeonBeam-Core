# NeonBeam Core — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env
#
# Values in .env are loaded by docker-compose.yml.
# Any variable also present in the 'environment' block of docker-compose.yml
# will be overridden by the compose file — remove that line in compose to let
# the .env value take effect.


# ── Serial / Telnet connection ──────────────────────────────────────────────
#
# Simulator (development, no hardware required — runs grblHAL Simulator on host):
COMM_SERIAL_PORT=socket://host.docker.internal:23

# Physical USB serial (Raspberry Pi wired to MCU) — uncomment and replace default above:
# COMM_SERIAL_PORT=/dev/ttyACM0      # USB CDC (grblHAL native USB)
# COMM_SERIAL_PORT=/dev/ttyUSB0      # CH340 / FT232 USB-serial adapter
# COMM_SERIAL_PORT=/dev/ttyAMA0      # Pi GPIO UART (pins 14/15)

# Network Telnet socket (ESP32 WiFi grblHAL board, or remote host simulator):
# COMM_SERIAL_PORT=socket://192.168.1.20:23

COMM_BAUD_RATE=115200   # Ignored for socket:// connections


# ── Logging ─────────────────────────────────────────────────────────────────
#
# Log verbosity — all hardware_comm.* loggers.
# DEBUG | INFO | WARNING | ERROR | CRITICAL       Default: INFO
#
#   DEBUG    → Everything, including raw serial bytes when COMM_LOG_VERBOSE_SERIAL=true
#   INFO     → Normal operation: job start/stop, connections, firmware changes
#   WARNING  → Recoverable issues: serial drops, buffer retries
#   ERROR    → Failures that halt a subsystem
#   CRITICAL → Process-level crashes only
COMM_LOG_LEVEL=INFO

# Where to write log records.
# stdout | file | both                             Default: stdout
#
#   stdout → available via `docker compose logs -f neonbeam-core`
#   file   → COMM_LOG_FILE on disk (container path, mapped via volume)
#   both   → recommended for production (structured + persistent)
COMM_LOG_OUTPUT=both

# Log file path inside the container.
# The docker-compose.yml volume mounts ./logs → /app/logs, so this file
# will appear on the host at ./logs/neonbeam_core.log.
COMM_LOG_FILE=/app/logs/neonbeam_core.log

# Rotate the log file after it reaches this size in bytes. Default: 10 MB
COMM_LOG_MAX_BYTES=10485760

# Number of rotated backup files to retain alongside the active log. Default: 5
COMM_LOG_BACKUP_COUNT=5

# Log every raw byte sent → MCU (TX) and received ← MCU (RX).
# ONLY active when COMM_LOG_LEVEL=DEBUG. Produces very high volume during
# GCode streaming — use for short debugging sessions only.
# true | false                                     Default: false
COMM_LOG_VERBOSE_SERIAL=false
